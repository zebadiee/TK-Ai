# vault/triggers.json - trigger definitions
# vault/capabilities.json - capability registry
# vault/solution_graph.json - example graph definitions
# vault/solution_graphs/ - versioned graph templates
# vault/signals.json - signal definitions
# vault/graph_index.json - graph registry index
